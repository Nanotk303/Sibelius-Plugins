			RadioButton { Title "preferer la note superieure" ID "IDC_UP" X "108" Y "134" Width "140" Height "14" StartGroup "0" Value "preferUp" Method SetFocus "0" }
			Text { Title "Chaque note est deplacee dans le registre le plus proche." ID "IDC_HELP" X "12" Y "163" Width "295" Height "14" RightAlign "0" Value Method SetFocus "0" }
			Button { Title "Annuler" ID "IDC_CANCEL" X "200" Y "194" Width "56" Height "14" DefaultButton "0" Value Method SetFocus "0" EndDialog "0" }
			Button { Title "Remapper" ID "IDC_OK" X "262" Y "194" Width "56" Height "14" DefaultButton "1" Value Method SetFocus "0" EndDialog "1" }
		}
	}
