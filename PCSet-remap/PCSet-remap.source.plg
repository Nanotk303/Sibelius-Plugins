{
	Initialize "() {
AddToPluginsMenu('PCSet-remap', 'Run');
}"
	Run "() {
if (Sibelius.ScoreCount = 0)
{
	Sibelius.MessageBox('PCSet-remap: ouvrez une partition avant de lancer le plug-in.');
	return False;
}

score = Sibelius.ActiveScore;
selection = score.Selection;
hasNotes = False;
for each NoteRest nr in selection
{
	if (nr.NoteCount > 0)
	{
		hasNotes = True;
	}
}

if (hasNotes = False)
{
	Sibelius.MessageBox('PCSet-remap: selectionnez au moins une note ou un passage contenant des notes.');
	return False;
}

if (ShowPitchClassDialog() = False)
{
	return False;
}

if (CountSelectedPitchClasses() = 0)
{
	Sibelius.MessageBox('PCSet-remap: selectionnez au moins une classe de hauteur.');
	return False;
}

score.Redraw = False;
changed = 0;
for each NoteRest nr in selection
{
	if (nr.NoteCount > 0)
	{
		for each note in nr
		{
			delta = NearestDelta(Mod12(note.Pitch));
			if (not(delta = 0))
			{
				TransposeNoteBySemitones(note, delta);
				changed = changed + 1;
			}
		}
	}
}
score.Redraw = True;

Sibelius.MessageBox('PCSet-remap: ' & changed & ' note(s) remappee(s).');
return True;
}"
	Mod12 "(value) {
result = value;
while (result < 0)
{
	result = result + 12;
}
while (result >= 12)
{
	result = result - 12;
}
return result;
}"
	PitchClassSelected "(pitchClass) {
if (pitchClass = 0) { return pcC; }
if (pitchClass = 1) { return pcCs; }
if (pitchClass = 2) { return pcD; }
if (pitchClass = 3) { return pcEb; }
if (pitchClass = 4) { return pcE; }
if (pitchClass = 5) { return pcF; }
if (pitchClass = 6) { return pcFs; }
if (pitchClass = 7) { return pcG; }
if (pitchClass = 8) { return pcAb; }
if (pitchClass = 9) { return pcA; }
if (pitchClass = 10) { return pcBb; }
return pcB;
}"
	CountSelectedPitchClasses "() {
count = 0;
for pc = 0 to 11
{
	if (PitchClassSelected(pc))
	{
		count = count + 1;
	}
}
return count;
}"
	NearestDelta "(sourcePc) {
if (PitchClassSelected(sourcePc))
{
	return 0;
}

for distance = 1 to 6
{
	downPc = Mod12(sourcePc - distance);
	upPc = Mod12(sourcePc + distance);
	downSelected = PitchClassSelected(downPc);
	upSelected = PitchClassSelected(upPc);

	if (downSelected and upSelected)
	{
		if (preferDown)
		{
			return 0 - distance;
		}
		return distance;
	}
	if (downSelected)
	{
		return 0 - distance;
	}
	if (upSelected)
	{
		return distance;
	}
}
return 0;
}"
	PitchClassName "(pitchClass) {
if (pitchClass = 0) { return 'C'; }
if (pitchClass = 1) { return 'C#'; }
if (pitchClass = 2) { return 'D'; }
if (pitchClass = 3) { return 'Eb'; }
if (pitchClass = 4) { return 'E'; }
if (pitchClass = 5) { return 'F'; }
if (pitchClass = 6) { return 'F#'; }
if (pitchClass = 7) { return 'G'; }
if (pitchClass = 8) { return 'Ab'; }
if (pitchClass = 9) { return 'A'; }
if (pitchClass = 10) { return 'Bb'; }
return 'B';
}"
	TransposeNoteBySemitones "(note, delta) {
sourceName = PitchClassName(Mod12(note.Pitch));
destinationName = PitchClassName(Mod12(note.Pitch + delta));
upward = delta > 0;
degree = Sibelius.CalculateDegree(sourceName, destinationName, upward);
intervalType = Sibelius.CalculateInterval(sourceName, destinationName, upward);
if (upward = False)
{
	degree = 0 - degree;
}
note.Transpose(degree, intervalType, False);
}"
	ShowPitchClassDialog "() {
reopenDialog = True;
while (reopenDialog)
{
	reopenDialog = False;
	if (displayAsNumbers)
	{
		result = Sibelius.ShowDialog(PCSetDialogNumbers, Self);
	}
	else
	{
		result = Sibelius.ShowDialog(PCSetDialogNames, Self);
	}

	if ((result = False) and (reopenDialog = False))
	{
		return False;
	}
}
return result;
}"
	SwitchToNumbers "() {
displayAsNumbers = True;
reopenDialog = True;
Sibelius.CloseDialog(PCSetDialogNames, Self, False);
}"
	SwitchToNames "() {
displayAsNumbers = False;
reopenDialog = True;
Sibelius.CloseDialog(PCSetDialogNumbers, Self, False);
}"
	PCSetDialogNames "PCSetDialogNames"
	{
		Title "PCSet-remap"
		X "310"
		Y "180"
		Width "330"
		Height "225"
		Controls
