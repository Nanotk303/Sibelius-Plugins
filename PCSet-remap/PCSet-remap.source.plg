			CheckBox { Title "C#" ID "IDC_CS" X "68" Y "34" Width "42" Height "14" Value "pcCs" Method SetFocus "0" }
			CheckBox { Title "D" ID "IDC_D" X "120" Y "34" Width "42" Height "14" Value "pcD" Method SetFocus "0" }
			CheckBox { Title "Eb" ID "IDC_EB" X "172" Y "34" Width "42" Height "14" Value "pcEb" Method SetFocus "0" }
			CheckBox { Title "E" ID "IDC_E" X "224" Y "34" Width "42" Height "14" Value "pcE" Method SetFocus "0" }
			CheckBox { Title "F" ID "IDC_F" X "276" Y "34" Width "42" Height "14" Value "pcF" Method SetFocus "0" }
			CheckBox { Title "F#" ID "IDC_FS" X "16" Y "58" Width "42" Height "14" Value "pcFs" Method SetFocus "0" }
			CheckBox { Title "G" ID "IDC_G" X "68" Y "58" Width "42" Height "14" Value "pcG" Method SetFocus "0" }
			CheckBox { Title "Ab" ID "IDC_AB" X "120" Y "58" Width "42" Height "14" Value "pcAb" Method SetFocus "0" }
			CheckBox { Title "A" ID "IDC_A" X "172" Y "58" Width "42" Height "14" Value "pcA" Method SetFocus "0" }
			CheckBox { Title "Bb" ID "IDC_BB" X "224" Y "58" Width "42" Height "14" Value "pcBb" Method SetFocus "0" }
			CheckBox { Title "B" ID "IDC_B" X "276" Y "58" Width "42" Height "14" Value "pcB" Method SetFocus "0" }
			Text { Title "Affichage:" ID "IDC_DISPLAY_LABEL" X "12" Y "88" Width "58" Height "14" RightAlign "0" Value Method SetFocus "0" }
			RadioButton { Title "Noms de notes" ID "IDC_DISPLAY_NAMES" X "72" Y "87" Width "92" Height "14" StartGroup "1" Value "displayNames" Method SetFocus "0" }
			RadioButton { Title "Entiers 0-11" ID "IDC_DISPLAY_NUMBERS" X "170" Y "87" Width "92" Height "14" StartGroup "0" Value "displayNumbers" Method "SwitchToNumbers" SetFocus "0" }
			Text { Title "En cas d'egalite:" ID "IDC_TIE_LABEL" X "12" Y "116" Width "92" Height "14" RightAlign "0" Value Method SetFocus "0" }
